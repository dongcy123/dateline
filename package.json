{
  "name": "timeline-os",
  "version": "0.1.0",
  "description": "单页面极简个人管理系统 — AI-powered bi-directional timeline for expense, todos, and notes",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "playground": "cd playground && npx serve .",
    "lint": "eslint .",
    "test": "jest",
    "types": "tsc --noEmit",
    "db:types": "supabase gen types typescript --local > types/supabase.ts",
    "db:migrate": "supabase migration up"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-safe-area-context": "~5.0.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "~18.3.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.0.0",
    "supabase": "^2.0.0",
    "typescript": "~5.3.0"
  },
  "private": true
}
